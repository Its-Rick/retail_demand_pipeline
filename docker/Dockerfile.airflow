# Dockerfile.airflow
# Extends official Airflow 2.8.1 with pandas pre-installed
# This avoids _PIP_ADDITIONAL_REQUIREMENTS running on every container start

FROM apache/airflow:2.8.1-python3.10

# Install pandas and numpy as the airflow user (not root)
RUN pip install --no-cache-dir \
    pandas==2.1.4 \
    numpy==1.26.3

# Note: psycopg2 is already included in the official airflow image