# Dockerfile.consumer
# Runs the Kafka e-commerce event consumer
FROM python:3.10-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    kafka-python==2.0.2 \
    psycopg2-binary==2.9.9 \
    python-dotenv==1.0.0

COPY kafka/consumer/ecommerce_consumer.py ./kafka/consumer/

ENV KAFKA_BOOTSTRAP_SERVERS=kafka:9092
ENV KAFKA_TOPIC=ecommerce_events
ENV KAFKA_GROUP_ID=retail-demand-pipeline
ENV DATA_LAKE_PATH=/app/data
ENV PYTHONUNBUFFERED=1

CMD ["python", "kafka/consumer/ecommerce_consumer.py"]
