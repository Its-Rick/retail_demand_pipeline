# =============================================================================
# .env.example
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=retail_dw
PG_USER=airflow
PG_PASSWORD=airflow
PG_JDBC_URL=jdbc:postgresql://localhost:5432/retail_dw

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ecommerce_events
KAFKA_DLQ_TOPIC=ecommerce_events_dlq
KAFKA_GROUP_ID=retail-demand-pipeline
KAFKA_PARTITIONS=6
CONSUMER_BATCH_SIZE=500
CONSUMER_FLUSH_SEC=30

# ── Data Lake ─────────────────────────────────────────────────────────────────
DATA_LAKE_PATH=./data
# For AWS S3:
# DATA_LAKE_PATH=s3://your-bucket/retail-lake
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_DEFAULT_REGION=us-east-1

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_HOME=/opt/spark
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=4g
SPARK_EXECUTOR_CORES=2
SPARK_SHUFFLE_PARTITIONS=50

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0jIkd-Q=
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here

# ── Monitoring ────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@retailpipeline.com

# ── Pipeline Settings ─────────────────────────────────────────────────────────
DQ_NULL_THRESHOLD=0.99
DQ_DUPLICATE_THRESHOLD=0.99
